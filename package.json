{
  "name": "podchain",
  "version": "1.0.0",
  "description": "Cryptographic proof-of-delivery protocol for Nigerian logistics APIs",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/sqlite": "./src/adapters/sqlite-adapter.ts"
  },
  "keywords": [
    "logistics",
    "proof-of-delivery",
    "cryptography",
    "non-repudiation",
    "ecdsa",
    "nigeria"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "bench": "bun run benchmarks/run-all.ts",
    "bench:crypto": "bun run benchmarks/crypto.bench.ts",
    "bench:chain": "bun run benchmarks/chain.bench.ts",
    "bench:pipeline": "bun run benchmarks/pipeline.bench.ts",
    "bench:vectors": "bun test benchmarks/vectors.test.ts",
    "bench:report": "bun run benchmarks/format-report.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
